{%- comment -%}
  Homepage FAQPage schema for key GEO questions (used when FAQ section is disabled).
{%- endcomment -%}
<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is SCORM and how does it work?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "SCORM (Shareable Content Object Reference Model) is a set of technical standards used to create and deliver online training content. SCORM guides programmers on how to write their code so it can seamlessly integrate with other eLearning software. It is the de facto industry standard for eLearning interoperability, specifically governing the communication between online learning content and Learning Management Systems (LMSs)."
        }
      },
      {
        "@type": "Question",
        "name": "Will the SCORM package work on all Learning Management Systems?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Most modern LMS platforms support SCORM 1.2 or SCORM 2004. However, it is always best to confirm compatibility with your LMS provider or test our demo module before purchasing. We have successfully implemented our SCORM packages on platforms including Docebo, TalentLMS, Absorb LMS, SAP Litmos, Cornerstone OnDemand, Moodle, Canvas LMS, Blackboard Learn, and many others."
        }
      },
      {
        "@type": "Question",
        "name": "How do I receive a SCORM package?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The standard SCORM package is generated according to SCORM 1.2 or SCORM 2004 (4th edition) standards, depending on the option you select, and will be shared with you within 24 hours after you complete your order. Custom branded SCORM packages take up to 7 business days. We generally send a download link from which you can retrieve the SCORM package for your LMS."
        }
      },
      {
        "@type": "Question",
        "name": "Why Should I Use SCORM?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Using SCORM offers interoperability across LMS platforms, reusability of training content, consistent learner experiences, detailed progress tracking and reporting, and lower development costs compared to custom one-off eLearning builds."
        }
      }
    ]
  }
</script>
