{%- unless template == 'index' or template == 'cart' or template == 'list-collections' or template == '404' -%}
<style>
  .breadcrumb span[aria-hidden="true"] {
    padding: 0 8px;
    display: inline-block;
  }
</style>
<nav class="breadcrumb" role="navigation" aria-label="breadcrumbs" style="margin-bottom: 20px; font-size: 0.9em;">
  <a href="{{ routes.root_url }}" title="Home">Home</a>
  
  {%- if template contains 'page' -%}
    <span aria-hidden="true">&rsaquo;</span>
    <span>{{ page.title }}</span>
    
  {%- elsif template contains 'product' -%}
    {%- if collection.url -%}
      <span aria-hidden="true">&rsaquo;</span>
      {{ collection.title | link_to: collection.url }}
    {%- elsif product.collections.size > 0 -%}
      <span aria-hidden="true">&rsaquo;</span>
      {{ product.collections.first.title | link_to: product.collections.first.url }}
    {%- endif -%}
    <span aria-hidden="true">&rsaquo;</span>
    <span>{{ product.title }}</span>
    
  {%- elsif template contains 'collection' and collection.handle -%}
    <span aria-hidden="true">&rsaquo;</span>
    {%- if current_tags -%}
      {%- capture url -%}/collections/{{ collection.handle }}{%- endcapture -%}
      {{ collection.title | link_to: url }}
      <span aria-hidden="true">&rsaquo;</span>
      <span>{{ current_tags | join: " + " }}</span>
    {%- else -%}
      <span>{{ collection.title }}</span>
    {%- endif -%}
    
  {%- elsif template == 'blog' -%}}
    <span aria-hidden="true">&rsaquo;</span>
    {%- if current_tags -%}
      {{ blog.title | link_to: blog.url }}
      <span aria-hidden="true">&rsaquo;</span>
      <span>{{ current_tags | join: " + " }}</span>
    {%- else -%}
    <span>{{ blog.title }}</span>
    {%- endif -%}
    
  {%- elsif template == 'article' -%}
    <span aria-hidden="true">&rsaquo;</span>
    {{ blog.title | link_to: blog.url }}
    <span aria-hidden="true">&rsaquo;</span>
    <span>{{ article.title }}</span>
    
  {%- else -%}
    <span aria-hidden="true">&rsaquo;</span>
    <span>{{ page_title }}</span>
  {%- endif -%}
</nav>
{%- endunless -%}