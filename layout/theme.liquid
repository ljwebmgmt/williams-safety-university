    {% style %}
  .herosection-slider .ss-slideshow .slideshow__slide .slideshow__text-wrapper .slideshow__text.visible .banner__heading{visibility:visible !important;}
.herosection-slider .ss-slideshow .slideshow__slide .slideshow__text-wrapper .slideshow__text.visible *{visibility:visible !important;}
.herosection-slider .ss-slideshow .slideshow__slide .slideshow__text-wrapper .slideshow__text.visible .button{visibility:visible !important;}
/* SS Slideshow Section Style */
.ss-slideshow .slideshow__media img.slideshow_img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}
.ss-slideshow__controls.hide_control_arrows .slider-button {
    display: none;
}
.ss-slideshow__controls.slideshow__controls {
    border: none;
    position: absolute;
    right: 0;
    top: 0;
    height: 100%;
    flex-direction: column;
}
.ss-slideshow__controls .slider_arrows {
    display: flex;
    position: absolute;
    top: 0;
    
    .slider-button {
        color: #fff;
        transition: .3s;

        svg.icon {
            height: 1rem;
        }

    }
    .slider-button:hover {
        color: #ffffff;
        transform: scale(1.1);
    }
}
.ss-slideshow__controls .slideshow__control-wrapper {
    flex-direction: column;

    span.dot, .slider-counter__link:hover span.dot {
        border-color: #fff;
        width: 1.5rem;
        height: 1.5rem;
    }

    .slider-counter__link--active span.dot {
        background-color: #ffffff;
    }
}
.ss-slideshow .slideshow__text.banner__box {
    max-width: 65rem;
}
.ss-slideshow .banner__text p{
  
}
.ss-slideshow .banner__text * {
    font-size: 2.2rem;
}
.ss-slideshow .banner__heading {
    font-weight: 600;
}
.ss-slideshow .banner__buttons .button {
    background-color: rgba(2, 69, 139, 0.59);
    border: solid 2px rgba(2, 69, 139, 0.59);
    font-size: 1.7rem;
    transition: .3s;

    &::after {
        box-shadow: none;
    }

    &:hover {
        background-color: transparent;
    }
}

@media screen and (max-width: 1150px){
.slide-column .slideshow__media.banner__media.media {
    display: none;
}	
.slide-column .slideshow__text-wrapper.banner__content {
    flex-direction: column-reverse;
padding: 0;
}
.slide-column .video-container {
    width: 100%;
}

.ss-slideshow .slide-column .slideshow__text.banner__box{
background:#242833;
height:100%;
max-width:100%;
padding:4rem 3.5rem;
}
}
@media screen and (max-width: 749px){
  .ss-slideshow .slide-column .slideshow__text.banner__box{
  padding:5rem 4.5rem;
  }
        .herosection-slider .ss-slideshow .slideshow__slide .slideshow__text-wrapper .slideshow__text .banner__heading{
          font-family:sans-serif;
        }
        .herosection-slider .ss-slideshow .slideshow__slide .slideshow__text-wrapper .slideshow__text .banner__text *{
          font-family:sans-serif;
        }
        .herosection-slider .ss-slideshow .slideshow__slide .slideshow__text-wrapper .slideshow__text .banner__buttons .button{
          font-family:sans-serif;
        }
}
      @media screen and (max-width: 480px){
        .herosection-slider .ss-slideshow .slideshow__slide .slideshow__text-wrapper .slideshow__text .banner__heading{
          font-size:18px;
        }
        .herosection-slider .ss-slideshow .slideshow__slide .slideshow__text-wrapper .slideshow__text .banner__text *{
          font-size:15px;
        }
        .herosection-slider .ss-slideshow .slideshow__slide .slideshow__text-wrapper .slideshow__text .banner__buttons .button{
          min-height:0;
          padding:0.7rem 1rem;
          font-size:13px;
        }
        .herosection-slider .ss-slideshow .slideshow__slide .slideshow__text-wrapper .slideshow__text{
          padding:2.5rem 1rem;
        }
      }
      .hdr-top-bar .topbar-item {
    flex-grow: 1;
    padding-right: 10px;
    display: flex;
}
.topbar-item.img-invert img.icon-img {
    filter: brightness(0) invert(1);
}
.topbar-item span, .topbar-item a span {
    font-size: 1rem;
    font-weight: 600;
}
.topbar-item .announcement-bar__message {
    display: flex;
    align-items: center;
}
.topbar-item a.link {
    text-decoration: none;
}
.modalbox-overlay {
    position: fixed;
    width: 100vw;
    height: 100vh;
    top: 0;
    left: 0;
    bottom: 0;
    right: 0;
    z-index: 100;
    background-color: #232323cc;
    display: none;
}
.modalbox-overlay.active {
    display: block;
}
.modalbox {
    position: fixed;
    right: 0;
    top: 0;
    background-color: #fff;
    z-index: 999;
    overflow-y: auto;
    overflow-x: hidden;
    transition: transform .5s ease 0s;
    width: 410px;
    height: 100%;
    padding: 40px 30px;
    transform: translate3d(410px,0,0);
    max-width: 90%;
}
.modalbox .modal-title {
    color: #121212;
    font-size: large;
    margin: 0;
    padding-bottom: 10px;
    border-bottom: 1px solid #bdbcbc;
}
.modalbox .modal-content {
    color: #121212;
    font-size: 15px;
}
.modalbox.active {
    transform: translateZ(0);
}
.topbar-item a.modal-popup {
    cursor: pointer;
}
.modalbox button.modal__close {
    position: absolute;
    right: 30px;
    top: 30px;
    background: none;
    border: none;
    padding: 0;
    width: 18px;
    cursor: pointer;
}
.hdr-top-bar .page-width {
    display: flex;
}
.hdr-top-bar.utility-bar .list-social {
    margin: 0;
    flex-wrap: nowrap;
}   
.hdr-top-bar .list-social__item {
    align-items: center;
    display: flex;
}
