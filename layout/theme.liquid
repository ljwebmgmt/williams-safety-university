<script>
  const videoPopup = document.getElementById('videoPopup_3');
  const slideshowElements = document.querySelectorAll('.ss-slideshow');

  // Create a MutationObserver to watch for style changes
  if (videoPopup) {
    const observer = new MutationObserver(() => {
      const isDisplayed = getComputedStyle(videoPopup).display === 'flex';

      slideshowElements.forEach(el => {
        if (isDisplayed) {
          el.style.zIndex = '9';
        } else {
          el.style.zIndex = '';
        }
      });
    });
    // Start observing the style attribute of videoPopup
    observer.observe(videoPopup, { attributes: true, attributeFilter: ['style'] });
  }
</script>

